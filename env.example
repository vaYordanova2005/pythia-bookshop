# ─── DATABASE ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=bibliotheca

# ─── SERVER ──────────────────────────────────────────────────────────────────
PORT=5173

# ─── SECURITY ────────────────────────────────────────────────────────────────
